+            # Skip samples with None or non-finite (NaN/+-inf) values. Uninitialized
+            # gauges expose these — e.g. SGLang's sglang:fwd_occupancy defaults to NaN
+            # before the first forward pass. orjson encodes NaN as JSON null, which then
+            # fails ServerMetricsRecordMessage validation on the consumer and drops the
+            # ENTIRE scrape (taking cache_hit_rate / cached_tokens_total with it). The
+            # `== float("inf")` check this replaces never caught NaN despite the old
+            # comment claiming it did.
+            if sample.value is None or not math.isfinite(sample.value):
                 continue
             label_key = tuple(sorted(sample.labels.items()))
             samples_by_labels[label_key] = sample.value
